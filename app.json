{
  "expo": {
    "name": "Orda_Customer",
    "slug": "Orda_Customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/gptOrdaLogo.png",
    "scheme": "ordacustomer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/gptOrdaLogo.png",
        "backgroundColor": "#70CFAF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.hephzibah108.Orda_Customer",
      "permissions": [
        "CAMERA",
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/gptOrdaLogo.png",
          "resizeMode": "contain",
          "backgroundColor": "#70CFAF",
          "enableFullScreen_legacy": true,
          "hideStatusBar_legacy": true,
          "hideHomeIndicator_legacy": true,
          "hideExponentText": true
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d357de0f-170a-4392-a09c-41ca52ddc214"
      }
    },
    "runtimeVersion": "1.0.0",

    "updates": {
      "url": "https://u.expo.dev/d357de0f-170a-4392-a09c-41ca52ddc214"
    }
  },
  "experiments": {
    "typedRoutes": true
  }
}
